# Copy to .env and fill in real values. docker-compose.yml reads these
# automatically; never commit a real .env file.

# --- Backend: prediction API ---
APP_ENV=development
API_KEY=dev-api-key
RATE_LIMIT_RPM=120

# --- Backend: accounts / report history (Postgres) ---
DATABASE_URL=postgresql+psycopg://cardio:cardio@db:5432/cardio
JWT_SECRET_KEY=change-this-to-a-long-random-secret-in-production

# --- Backend: document upload (RAG extraction) ---
# Get a free key at https://console.groq.com. Without it, POST /extract
# returns a clear 503 rather than failing unpredictably.
GROQ_API_KEY=

# --- Frontend ---
# Where the Next.js rewrite proxies /api/* requests. Point this at your
# deployed backend URL in production.
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_KEY=dev-api-key
