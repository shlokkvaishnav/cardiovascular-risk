# Copy to .env and fill in real values. docker-compose.yml reads these
# automatically; never commit a real .env file.

# --- Backend: prediction API ---
APP_ENV=development
API_KEY=dev-api-key
RATE_LIMIT_RPM=120

# --- Backend: accounts / report history (Postgres) ---
DATABASE_URL=postgresql+psycopg://cardio:cardio@db:5432/cardio
JWT_SECRET_KEY=change-this-to-a-long-random-secret-in-production

# --- Backend: document upload (RAG extraction) ---
# Get a free key at https://console.groq.com. Without it, POST /extract
# returns a clear 503 rather than failing unpredictably.
GROQ_API_KEY=

# --- Frontend ---
# Local docker-compose only. In production the frontend runs on Vercel
# instead, where these two are set directly in the Vercel project's
# environment variables (not read from this file):
#   NEXT_PUBLIC_API_URL -- http://<VM_PUBLIC_IP> (or your domain) --
#                           Vercel's server-side rewrite calls this directly,
#                           so plain HTTP is fine even without a domain
#   NEXT_PUBLIC_API_KEY -- must match API_KEY below
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_KEY=dev-api-key

# --- Production VM only (docker-compose.prod.yml), backend + Postgres ---
# Leave unset (defaults to ":80", plain HTTP) until you have a domain's DNS
# pointed at the VM's IP -- then set it to that domain and Caddy will
# provision a Let's Encrypt cert automatically.
SITE_ADDRESS=:80
